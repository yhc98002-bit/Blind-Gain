+@lru_cache(maxsize=8)
+def _load_caption_pixel_index_cached(
+    path_fingerprints: tuple[tuple[str, str], ...]
+) -> tuple[tuple[str, str], ...]:
+    captions: dict[str, str] = {}
+    for path, _ in path_fingerprints:
+        with open(path, encoding="utf-8") as handle:
+            for line in handle:
+                if not line.strip():
+                    continue
+                row = json.loads(line)
+                image_hash = str(row["image_sha256"])
+                image_path = str(row.get("image_path", ""))
+                if not image_path or not os.path.isfile(image_path):
+                    raise ValueError(
+                        f"caption store lacks a readable source image for pixel indexing: {path}"
+                    )
+                pixel_hash = _pixel_sha256(image_path)
+                caption = str(row["caption"]).strip()
+                if pixel_hash in captions and captions[pixel_hash] != caption:
+                    raise ValueError(
+                        f"conflicting captions for normalized pixel hash {pixel_hash}"
+                    )
+                captions[pixel_hash] = caption
+    return tuple(sorted(captions.items()))
+
+
+def load_caption_pixel_index(paths: list[str]) -> dict[str, str]:
+    fingerprints = tuple((path, _sha256_file(path)) for path in paths)
+    return dict(_load_caption_pixel_index_cached(fingerprints))
