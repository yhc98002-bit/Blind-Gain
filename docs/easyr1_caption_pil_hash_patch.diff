+def _pixel_sha256(image: Union[dict[str, Any], ImageObject, str, bytes]) -> str:
+    if isinstance(image, str):
+        with Image.open(image) as source:
+            normalized = source.convert("RGBA")
+    elif isinstance(image, dict):
+        with Image.open(BytesIO(image["bytes"])) as source:
+            normalized = source.convert("RGBA")
+    elif isinstance(image, bytes):
+        with Image.open(BytesIO(image)) as source:
+            normalized = source.convert("RGBA")
+    elif isinstance(image, ImageObject):
+        normalized = image.convert("RGBA")
+    else:
+        raise TypeError(f"unsupported caption image source: {type(image).__name__}")
+    digest = hashlib.sha256()
+    digest.update(normalized.width.to_bytes(4, "big"))
+    digest.update(normalized.height.to_bytes(4, "big"))
+    digest.update(normalized.tobytes())
+    return digest.hexdigest()
+
