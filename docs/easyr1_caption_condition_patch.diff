+CAPTION_INSERT_TEMPLATE = "\n[Question-blind image description {index}: {caption}]\n"
+
+
+def _sha256_file(path: str) -> str:
+    digest = hashlib.sha256()
+    with open(path, "rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def load_caption_store(paths: list[str]) -> tuple[dict[str, str], dict[str, str]]:
+    rows: dict[str, tuple[str, str, str]] = {}
+    for path in paths:
+        with open(path, encoding="utf-8") as handle:
+            for line in handle:
+                if not line.strip():
+                    continue
+                row = json.loads(line)
+                forbidden = {"question", "problem", "answer", "answer_a", "answer_b"} & row.keys()
+                if row.get("schema_version") != "blind-gains.caption-store.v1" or forbidden:
+                    raise ValueError(f"caption store violates the question-blind contract: {path}")
+                image_hash = str(row.get("image_sha256", ""))
+                caption = str(row.get("caption", "")).strip()
+                model = str(row.get("caption_model_path", "")).strip()
+                prompt_hash = str(row.get("caption_prompt_sha256", "")).strip()
+                if len(image_hash) != 64 or not caption or not model or len(prompt_hash) != 64:
+                    raise ValueError(f"caption store row is incomplete: {path}")
+                value = (caption, model, prompt_hash)
+                if image_hash in rows and rows[image_hash] != value:
+                    raise ValueError(f"conflicting captions for image hash {image_hash}")
+                rows[image_hash] = value
+    if not rows:
+        raise ValueError("caption image_condition requires a nonempty caption store")
+    models = {value[1] for value in rows.values()}
+    prompts = {value[2] for value in rows.values()}
+    if len(models) != 1 or len(prompts) != 1:
+        raise ValueError("caption store mixes caption models or prompts")
+    canonical = json.dumps(
+        [(image_hash, *rows[image_hash]) for image_hash in sorted(rows)],
+        ensure_ascii=True,
+        separators=(",", ":"),
+    ).encode("utf-8")
+    metadata = {
+        "caption_model_path": next(iter(models)),
+        "caption_prompt_sha256": next(iter(prompts)),
+        "caption_store_sha256": hashlib.sha256(canonical).hexdigest(),
+    }
+    return {image_hash: value[0] for image_hash, value in rows.items()}, metadata
 
 
