+IMAGE_CONDITIONS = {"real", "gray", "noise", "none"}
+
+
+def condition_image(image: ImageObject, condition: str, seed: int) -> ImageObject:
+    if condition == "real":
+        return image
+    if condition == "gray":
+        return Image.new("RGB", image.size, (128, 128, 128))
+    if condition == "noise":
+        digest = hashlib.sha256()
+        digest.update(str(seed).encode("ascii"))
+        digest.update(image.size[0].to_bytes(4, "big"))
+        digest.update(image.size[1].to_bytes(4, "big"))
+        digest.update(image.tobytes())
+        rng = np.random.default_rng(int.from_bytes(digest.digest()[:8], "big"))
+        pixels = rng.integers(0, 256, size=(image.height, image.width, 3), dtype=np.uint8)
+        return Image.fromarray(pixels, mode="RGB")
+    raise ValueError(f"image conditioning requires pixels, found {condition!r}")
+
